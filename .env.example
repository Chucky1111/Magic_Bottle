# --- 新配置系统格式（pydantic-settings） ---
# 以下变量是新配置系统需要的格式
# 注意：变量名使用双下划线分隔嵌套配置

# 如果未设置，将回退到默认 LLM 配置
READER_LLM__API_KEY=your_api_key_here
READER_LLM__BASE_URL=https://api.deepseek.com
READER_LLM__MODEL=deepseek-chat
READER_LLM__MAX_RETRIES=5
READER_LLM__RETRY_DELAY=2.0
READER_LLM__TIMEOUT_SECONDS=120
READER_LLM__TEMPERATURE=0.7
READER_LLM__MAX_TOKENS=8000



# --- Writer LLM 配置（写作模块专用）---
# 如果未设置，将回退到默认 LLM 配置
# 我用的是dmx这个中转平台，主要是为了更好地控制请求和重试机制，同时也能兼容多种后端模型，你也可以直接使用OpenAI或其他平台的API，只需调整API_KEY和BASE_URL即可。
WRITER_LLM__API_KEY=your_api_key_here
WRITER_LLM__BASE_URL=https://www.dmxapi.cn/v1
WRITER_LLM__MODEL=gemini-3-pro-preview

WRITER_LLM__MAX_RETRIES=5
WRITER_LLM__RETRY_DELAY=2.0
WRITER_LLM__TIMEOUT_SECONDS=120
WRITER_LLM__TEMPERATURE=0.7
WRITER_LLM__MAX_TOKENS=8000


# --- 默认 LLM 配置 ---
# 基础 LLM 配置，其他模块如未单独配置则使用此配置
LLM__API_KEY=your_api_key_here
LLM__BASE_URL=https://api.deepseek.com
LLM__MODEL=deepseek-reasoner

# LLM__API_KEY=your_api_key_here
# LLM__BASE_URL=https://www.dmxapi.cn/v1
# LLM__MODEL=gemini-3-pro-preview


LLM__MAX_RETRIES=5
LLM__RETRY_DELAY=2.0
LLM__TIMEOUT_SECONDS=120
LOGGING__LEVEL=INFO
STORAGE__STATE_FILE=./state.json
STORAGE__DATA_DIR=./projects
WORKFLOW__MAX_CONTEXT_TOKENS=128000
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=8000


# 这个模块有bug，不要开启
# --- 调度配置 ---
# 启用时间调度控制
SCHEDULER__ENABLED=false
# 运行时间窗口，格式 HH:MM-HH:MM，例如 09:00-18:00
SCHEDULER__TIME_WINDOW=00:00-23:59
# 检查时间窗口的间隔秒数
SCHEDULER__CHECK_INTERVAL_SECONDS=60
# 窗口外暂停行为：sleep（休眠等待）或 exit（优雅退出）
SCHEDULER__PAUSE_BEHAVIOR=sleep


# --- 用户灵感配置 ---
# 用户灵感注入功能基本配置
USER_IDEA__ENABLED=true
USER_IDEA__DIRECTORY=./prompts/user_idea
USER_IDEA__COMPLETED_PREFIX=completed_
USER_IDEA__MAX_RETRIES=3

# 用户协同模式配置（可选）
# 启用后，系统会根据灵感数量自动规划章节数,就是说如果有五条灵感，那写五条就会写五章，如果想要一直写，就把这个功能关掉，或者注释掉
# USER_IDEA__COLLABORATIVE_MODE=true
# USER_IDEA__AUTO_CC_ENABLED=true
# USER_IDEA__MIN_CHAPTERS_PER_IDEA=1
